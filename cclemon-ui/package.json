{
  "name": "shoes-reborn",
  "version": "0.0.1",
  "description": "ui for cclemon",
  "productName": "shoes-reborn",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint --ext .js,.ts,.vue ./",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "dev": "set ENV_FILE=local&& quasar dev",
    "build": "quasar build",
    "build:dev": "set ENV_FILE=dev&& quasar build",
    "build:sit": "set ENV_FILE=sit&& quasar build",
    "build:prod": "set ENV_FILE=prod&& quasar build",
    "build:demo": "set ENV_FILE=demo&& quasar build -m pwa",
    "deploy:pages": "npm run build:demo && wrangler pages deploy"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "axios": "^1.2.1",
    "pinia": "^2.0.11",
    "quasar": "^2.16.0",
    "register-service-worker": "^1.7.2",
    "vue": "^3.4.18",
    "vue-i18n": "^9.2.2",
    "vue-router": "^4.0.12"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^2.0.0",
    "@playwright/test": "^1.58.2",
    "@quasar/app-vite": "^2.0.0-beta.12",
    "@types/node": "^20.5.9",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "autoprefixer": "^10.4.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "msw": "^2.12.10",
    "prettier": "^3.0.3",
    "typescript": "~5.3.0",
    "vite-plugin-checker": "^0.6.4",
    "vue-tsc": "^1.8.22",
    "workbox-build": "^7.4.0",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "wrangler": "^4.71.0"
  },
  "engines": {
    "node": "^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
